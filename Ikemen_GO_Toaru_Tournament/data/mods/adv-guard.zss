[Function soundNumber()]
let sound = 10;
let check = -1;
if(name = "Kamijou Touma"){let sound = 1*$sound+random%5;let check = 1;}
if(name = "Misaka Mikoto"){let sound = 2*$sound+random%3;let check = 1;}
if(name = "Index (John's Pen)"){let sound = 3*$sound+random%3;let check = 1;}
if(name = "Stiyl Magnus"){let sound = 4*$sound+random%3;let check = 1;}
if(name = "Kanzaki Kaori"){let sound = 5*$sound+random%3;let check = 1;}
if(name = "Himegami Aisa"){let sound = 6*$sound+random%2;let check = 1;}
if(name = "Accelerator (Sisters)"){let sound = 8*$sound+random%3;let check = 1;}
if(name = "kuroko_s"){let sound = 9*$sound+random%3;let check = 1;}
if(name = "Tsuchimikado Motoharu"){let sound = 10*$sound+random%3;let check = 1;}
if(name = "Suzushina Yuriko"){let sound = 11*$sound+random%2;let check = 1;}
if(name = "Last_Order"){let sound = 12*$sound+random%4;let check = 1;}
if(name = "Kazakiri Hyouka"){let sound = 13*$sound+random%3;let check = 1;}
if(name = "Lola_Stuart"){let sound = 14*$sound+random%3;let check = 1;}
if(name = "Accelerator"){let sound = 15*$sound+random%3;let check = 1;}
if(name = "Hamazura Shiage"){let sound = 16*$sound+random%3;let check = 1;}
if(name = "Kakine Teitoku"){let sound = 17*$sound+random%3;let check = 1;}
if(name = "Mugino Shizuri"){let sound = 18*$sound+random%3;let check = 1;}
if(name = "Kinuhata Saiai"){let sound = 19*$sound+random%3;let check = 1;}
if(name = "Sogiita Gunha"){let sound = 20*$sound+random%3;let check = 1;}
if(name = "Thor"){let sound = 21*$sound+random%2;let check = 1;}
if(name = "Kakine Teitoku (DM)"){let sound = 22*$sound+random%3;let check = 1;}
if(name = "Hokaze Junko"){let sound = 23*$sound+random%3;let check = 1;}
if(name = "Kamisato Kakeru"){let sound = 24*$sound+random%3;let check = 1;}
if(name = "neco-misaka"){let sound = 25*$sound+random%3;let check = 1;}
if ($check=-1){let sound = -1;}
playSnd{
		value: F 750, $sound;
		channel: 0;
		#volumescale: 200;
	}

[Function additionalFX()]
if name = "Last_Order" {
	if animElem = 2{
		explod{
			anim: 211;
			#id: 20001;
			sprpriority: 999;
			postype: p1;
			scale: 1,1;
			pos: 55,-48;
			removeongethit: 1;
			bindtime: -1;
			ownpal: 1;
		}
	}
	#if time = 0 {removeExplod {id: 20001}}
}


[Function animation() anim]
let anim = 220;

if(name = "Index (John's Pen)"){
	let anim = 0;
	helper{
		helpertype: normal;
		name: "Explosion";
		id: 212;
		stateno: 212;
		pos: 0,-0;
		postype: p1;
		facing: 1;
		keyctrl: 0;
		ownpal: 1;
		supermovetime: 0;
		pausemovetime: 0;
	}
}
if(name = "Kumagawa Misogi" || name = "Last_Order"){let anim = 210;}
if(name = "neco-misaka"){let anim = 221;}
if(name = "Accelerator" || name = "Accelerator (Sisters)"){let anim = 222;}
if(name = "Kamijou Touma"){let anim = 225;}
if(name = "Lola_Stuart"){let anim = 230;}
if(name = "Misaka Mikoto" || name = "Kamisato Kakeru"){let anim = 240;}
if(name = "Kinuhata Saiai"){let anim = 1005;}




#pushblock
[StateDef 7211184;
type: U;
movetype: I;
physics: N;
ctrl: 0;
velset: 0,0;
poweradd:-1000;]


if (time = 0){
	explod{
		anim: F 8105;
		postype: p1;
		pos: ifelse(pos y<0,const(size.air.front),const(size.ground.front))+10,ifelse(map(guardAnim)%10!=0,const(size.mid.pos.y),const(size.head.pos.y))+10;
		ownpal: 1;
		bindtime: 1;
		sprpriority: 2;
		scale: const(size.xscale),const(size.yscale);
		pausemovetime: 99999999;
	}
	helper{
		id: 7211185;
		stateno: 7211185;
		pos: -10,0;
		facing: 1;
		size.ground.back: 20;
		size.ground.front: 20;
		size.height: 240;
		pausemovetime: 99999999;
	}
}
velSet{x: 0; y: 0}
if pos y<0 {
	changeAnim{value: 152}
	stateTypeSet{
		statetype: A;
		physics: A;
	}
}
else{
	if (command = "holddown"){
		changeAnim{value: 151}
		stateTypeSet{
			statetype: C;
			physics: C;
		}
	}
	else{
		changeAnim{value: 150}
		stateTypeSet{
			statetype: S;
			physics: S;
		}
	}
}
if (time <= 1){
	notHitBy{
		value: SCA;
		time: 1;
	}
}

if (time = 1){
	playSnd {value: F 4, 1}
	changeState{
		value: 151+(command = "holddown")*2+(pos y<0)*4;
		ctrl: 0;
	}
}


[StateDef 7211185;
type: S;
movetype: I;
physics: N;
velset: 0,0;
anim: F 7211184;]

makeDust{
	pos: p2Dist x, 0;
	pos2: p2Dist x - random%11,0;
}


playerPush{value: 1}

notHitBy{
	value: SCA;
	time: 1;
}
if time = 0 {
	velSet{x: 20}
}

if time>0 {
	velAdd{x: -1}
}

if time = 15 {
	destroySelf{}
}

#guardcancel
[StateDef 7211186;
type: U;
ctrl: 0;
velset: 0,0;
sprpriority: 5;
poweradd:-1000;]

notHitBy{
	value: SCA;
	time: 1;
}
posFreeze{value: 1}

if time = 0{
	#var(1):=0;
	changeAnim{value: 140 + (stateType = C) + (stateType = A)*2}
	call soundNumber();
	helper{
		helpertype: Normal;
		stateno: 7211188;
		id: 8350;
		name: "Zero Counter";
		postype: P1;
		pos: ifelse(pos y<0,const(size.air.front),const(size.ground.front))+10,ifelse(map(guardAnim)%10!=0,const(size.mid.pos.y),const(size.head.pos.y))+10;#20, -65
		supermovetime: 255;
		ownpal: 1;
	}
	superPause{
		time: 16;
		movetime: 16;
		p2defmul: 1;
		anim: -1;
		#sound: F 750,0;
		darken: 0;
	}
	playSnd{
		value: F 750,0;
		volumescale: 50;
	}
}

if animTime = 0 && anim=[140,142]{
	changeAnim{value: 0}
}

if time>=16{
	changeState{value: 7211187}
}

[StateDef 7211187;
type: S;
movetype: A;
physics: S;
ctrl: 0;
velset: 10,0;
sprpriority: 5;]

notHitBy{
	value: SCA;
	time: 1;
}

if time = 0 {
	posSet{y: 0}
	let anim = call animation();
	changeAnim{value: $anim}
	if !moveContact {
		hitDef{
			attr: S, SA;
			damage: 65,10;
			priority: 5,Hit;
			hitflag: MAF;
			guardflag: MA;
			animtype: hard;
			air.animtype: low;
			fall.animtype: low;
			pausetime: 0,11;
			sparkno: 8220;
			sparkxy: -25,const(size.mid.pos.y);
			guard.sparkno: -1;
			hitsound: F 4,0;
			#guardsound: s0,9;
			ground.type: Low;
			ground.slidetime: 20;
			ground.hittime: 20;
			ground.velocity: -6,-6;
			guard.velocity: -8;
			air.type: Low
			air.velocity: -6,-4;
			airguard.velocity: -4,-3;
			ground.cornerpush.veloff: 0;
			air.cornerpush.veloff: 0;
			air.hittime: 20;
			kill: 0;
			guard.kill: 0;
			fall.kill: 0;
			fall: 1;
			air.fall: 1;
			yaccel: .36;
			id: stateno;
			p2facing: 1;
			getpower: 0,0;
			givepower: 0,0;
		}
	}
}
# if movecontact{
	# var(1):=1;
# }

call additionalFX();

if time<=10{
	notHitBy{value: SCA}
	ignoreHitPause {
		palFx{
			add: 128,128,192;
			time: 1;
		}
	}
}
if animTime=0 {
	changeState{
		value: 0;
		ctrl: 1;
	}
}
if time > 13 && helper(212),anim=212 && helper(212),animtime=0 {
	changeState{
		value: 1;
		ctrl: 0;
	}
}

[StateDef 7211188;
type: A;
physics: N;
movetype: I;
anim: F 9999;
ctrl: 0;
velset: 0,0;]

bgPalFx{
	time: 1;
	color: 16 * time;
	mul: 16 * time, 16 * time, 16 * time;
}

if time=0 {
	#circle
	explod{
		anim: F 8350;
		id: 1;
		sprpriority: 3;
		postype: P1;
		removetime: 16;
		supermovetime: -1;
		ownpal: 1;
	}
	#lightning
	explod{
		anim: F 8351;
		id: 2;
		sprpriority: -2;
		postype: P1;
		pos: 0, -ceil(pos y);
		supermovetime: -1;
		ownpal: 1;
		scale: 2,2;
	}
}
if numExplod(1){
	modifyExplod{
		id: 1;
		scale: (0.0625 * time)*2, (0.0625 * time)*2;
		trans: addalpha;
		alpha: 256 - (16 * time), 256;
	}
}

if time>=16 {destroySelf{}}

[StateDef -4]

if (roundState=2 && (command = "guardcancel") && prevStateNo!=7211186 && stateNo=[150,155] && power>=1000) && stateType!=A{
	changeState{value: 7211186}
}
if (roundState=2 && (command = "pushblock") && prevStateNo!=7211184 && stateNo=[150,155] && power>=1000){
	changeState{value: 7211184}
}