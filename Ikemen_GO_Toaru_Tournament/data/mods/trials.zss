# Mugen style Training Mode global code
# maps set via Pause Menu (menu.lua)
# _iksys_trialsDummyControl: 0 - cooperative, 1 - ai, 2 - manual
# _iksys_trialsGuardMode: 0 - none, 1 - auto, 2 - all, 3 - random
# _iksys_trialsFallRecovery: 0 - none, 1 - ground, 2 - air, 3 - random
# _iksys_trialsDummyMode: 0 - stand, 1 - crouch, 2 - jump, 3 - wjump
# _iksys_trialsDistance: 0 - any, 1 - close, 2 - medium, 3 - far
# _iksys_trialsButtonJam: 0 - none, 1-9 - a/b/c/x/y/z/s/d/w
# _iksys_trialsPosX: value: 

#===============================================================================
# Functions
#===============================================================================
[Function TrialsRecovery(pn)]
# Life recovery
if playerId($pn),moveType = H || playerId($pn),dizzy {
	mapSet{map: "_iksys_trialsLifeTimer"; value: 0; redirectid: $pn}
} else {
	mapAdd{map: "_iksys_trialsLifeTimer"; value: 1; redirectid: $pn}
}
if playerId($pn),map(_iksys_trialsLifeTimer) >= 60 {
	if playerId($pn),map(_iksys_trialsSetLife) > 0 {
		lifeSet{value: playerId($pn),map(_iksys_trialsSetLife); redirectid: $pn}
		redLifeSet{value: playerId($pn),map(_iksys_trialsSetLife); redirectid: $pn}
	} else {
		lifeSet{value: playerId($pn),lifeMax; redirectid: $pn}
		redLifeSet{value: playerId($pn),lifeMax; redirectid: $pn}
	}
	mapSet{map: "_iksys_trialsLifeTimer"; value: 0; redirectid: $pn}
}
# Power recovery
if playerId($pn),ctrl = 0 {
	mapSet{map: "_iksys_trialsPowerTimer"; value: 0; redirectid: $pn}
} else if playerId($pn),map(_iksys_trialsPowerTimer) >= 60 {
	powerSet{value: playerId($pn),powerMax; redirectid: $pn}
	mapSet{map: "_iksys_trialsPowerTimer"; value: 0; redirectid: $pn}
} else {
	mapAdd{map: "_iksys_trialsPowerTimer"; value: 1; redirectid: $pn}
}

[Function TrialsInitialPosition(pn)]
# Get initial positions
#for pn = 1; 2; 1 {
	mapSet{map:"_iksys_trialsPosX"; value: playerId($pn),pos x; redirectID: $pn;}
	mapSet{map:"_iksys_trialsPosY"; value: playerId($pn),pos y; redirectID: $pn;}
	mapSet{map:"_iksys_trialsCameraPosX"; value: playerId($pn),CameraPos x; redirectID: $pn;}
	mapSet{map:"_iksys_trialsCameraPosY"; value: playerId($pn),CameraPos y; redirectID: $pn;}
	mapSet{map:"_iksys_trialsScreenPosX"; value: playerId($pn),ScreenPos x; redirectID: $pn;}
	mapSet{map:"_iksys_trialsScreenPosY"; value: playerId($pn),ScreenPos y; redirectID: $pn;}
#}

[Function TrialsReposition(pn)]
#Camera{view: free; pos:0,0;}
#for pn = 1; 2; 1 {
	if playerId($pn), map(_iksys_trialsPosX) != 0 {posSet{x: playerId($pn), map(_iksys_trialsPosX); y: playerId($pn), map(_iksys_trialsPosY); redirectID: $pn;}}
#}

