#===============================================================================
# Global states (not halted by Pause/SuperPause, no helper limitations)
#===============================================================================
[StateDef -4]

ignoreHitPause if gameMode != "trials" || isHelper || teamSide != 2 {
	# Do nothing, not trials more or statedef executed by helper or not P2
} else ignoreHitPause if roundState = 0 {
	# Round start reset
	powerSet{value: playerId(56),powerMax; redirectid: 56}
	powerSet{value: playerId(57),powerMax; redirectid: 57}
	mapSet{map: "_iksys_trialsLifeTimer"; value: 0;}
	mapSet{map: "_iksys_trialsPowerTimer"; value: 0;}
	mapSet{map: "_iksys_trialsDirection"; value: 0;}
	mapSet{map: "_iksys_trialsAirJumpNum"; value: 0;}
	mapSet{map: "_iksys_trialsReposition"; value: 0;}
	call TrialsInitialPosition(56);
	call TrialsInitialPosition(57);
} else ignoreHitPause if roundState = 2 {
	assertSpecial{flag: noKo; redirectid: 56}
	assertSpecial{flag: noKo; redirectid: 57}
	# Life and Power recovery
	call TrialsRecovery(56);
	call TrialsRecovery(57);
	# Dummy Control: Cooperative
	if aiLevel = 0 && map(_iksys_trialsDummyControl) = 0 {
		# Guard mode: Random
		if map(_iksys_trialsGuardMode) = 3 {
			if random < 500 {
				assertSpecial{flag: autoGuard}
			}
		# Guard mode: All
		} else if map(_iksys_trialsGuardMode) = 2 {
			assertSpecial{flag: autoGuard}
		# Guard mode: Auto
		} else if map(_iksys_trialsGuardMode) = 1 {
			if moveType = H || stateNo = const(StateDownedGetHit_gettingUp) {
				mapSet{map: "_iksys_trialsAutoGuardTimer"; value: 15;}
			} else {
				mapSet{map: "_iksys_trialsAutoGuardTimer"; value: (map(_iksys_trialsAutoGuardTimer) - 1);}
			}
			if map(_iksys_trialsAutoGuardTimer) > 0 {
				assertSpecial{flag: autoGuard}
			}
		}
		# Distance
		let dir = 0;
		if map(_iksys_trialsDistance) != 0 {
			# Close
			if map(_iksys_trialsDistance) = 1 && p2BodyDist x > const240p(10) {
				let dir = 1;
				mapSet{map: "_iksys_trialsDirection"; value: 1;}
			# Medium
			} else if map(_iksys_trialsDistance) = 2 {
				if p2BodyDist x > const240p(130) {
					let dir = 1;
					mapSet{map: "_iksys_trialsDirection"; value: 1;}
				} else if p2BodyDist x < const240p(80) && backEdgeBodyDist > const240p(10) {
					let dir = -1;
					mapSet{map: "_iksys_trialsDirection"; value: -1;}
				}
			# Far
			} else if map(_iksys_trialsDistance) = 3 {
				if p2BodyDist x < const240p(260) && backEdgeBodyDist > const240p(10) {
					let dir = -1;
					mapSet{map: "_iksys_trialsDirection"; value: -1;}
				}
			# Reset to Center
			} else if map(_iksys_trialsDistance) = 4 {

			}
		}
		if map(_iksys_trialsDirection) != 0 {
			# if adjusting position is no longer needed
			if $dir = 0 {
				# maintain assertion only if dummy and nearest P1 are moving in the same direction
				if vel x * enemyNear,vel x >= 0 || backEdgeBodyDist = 0 || enemyNear,backEdgeBodyDist = 0 {
					mapSet{map: "_iksys_trialsDirection"; value: 0;}
				}
			}
			# if dummy should move forward and player is not trying to move dummy back
			if map(_iksys_trialsDirection) = 1 && command != "holdback" {
				if facing = 1 {
					assertInput{flag: R}
					# if numHelper {
						# for i = 1; numHelper; 1 {
							# assertInput{flag: R; redirectID: helperIndex($i), ID}
						# }
					# }
				} else {
					assertInput{flag: L}
					# if numHelper {
						# for i = 1; numHelper; 1 {
							# assertInput{flag: L; redirectID: helperIndex($i), ID}
						# }
					# }
				}
			# if dummy should move backward and player is not trying to move dummy forward
			} else if map(_iksys_trialsDirection) = -1 && command != "holdfwd" {
				if facing = 1 {
					assertInput{flag: L}
					# if numHelper {
						# for i = 1; numHelper; 1 {
							# assertInput{flag: L; redirectID: helperIndex($i), ID}
						# }
					# }
				} else {
					assertInput{flag: R}
					# if numHelper {
						# for i = 1; numHelper; 1 {
							# assertInput{flag: R; redirectID: helperIndex($i), ID}
						# }
					# }
				}
			}
		} else {
			# Dummy mode
			# Crouch
			if map(_iksys_trialsDummyMode) = 1 {
				assertInput{flag: D}
				# if numHelper {
					# for i = 1; numHelper; 1 {
						# assertInput{flag: D; redirectID: helperIndex($i), ID}
					# }
				# }
			# Jump
			} else if map(_iksys_trialsDummyMode) = 2{
				assertInput{flag: U}
				# if numHelper {
					# for i = 1; numHelper; 1 {
						# assertInput{flag: U; redirectID: helperIndex($i), ID}
					# }
				# }
			# W Jump
			} else if map(_iksys_trialsDummyMode) = 3{
				if vel y >= 0 {
					assertInput{flag: U}
					# if numHelper {
						# for i = 1; numHelper; 1 {
							# assertInput{flag: U; redirectID: helperIndex($i), ID}
						# }
					# }
				}
			} else{
				# Do nothing
			}
			# Button jam
			if map(_iksys_trialsButtonJam) > 0 {
				if map(_iksys_trialsButtonJamDelay) > 0 {
					mapAdd{map: "_iksys_trialsButtonJamDelay"; value: -1}
				} else {
					mapSet{map: "_iksys_trialsButtonJamDelay"; value: 11;}
					if map(_iksys_trialsButtonJam) = 1 {
						assertInput{flag: a}
						# if numHelper {
							# for i = 1; numHelper; 1 {
								# assertInput{flag: a; redirectID: helperIndex($i), ID}
							# }
						# }
					} else if map(_iksys_trialsButtonJam) = 2 {
						assertInput{flag: b}
						# if numHelper {
							# for i = 1; numHelper; 1 {
								# assertInput{flag: b; redirectID: helperIndex($i), ID}
							# }
						# }
					} else if map(_iksys_trialsButtonJam) = 3 {
						assertInput{flag: c}
						# if numHelper {
							# for i = 1; numHelper; 1 {
								# assertInput{flag: c; redirectID: helperIndex($i), ID}
							# }
						# }
					} else if map(_iksys_trialsButtonJam) = 4 {
						assertInput{flag: x}
						# if numHelper {
							# for i = 1; numHelper; 1 {
								# assertInput{flag: x; redirectID: helperIndex($i), ID}
							# }
						# }
					} else if map(_iksys_trialsButtonJam) = 5 {
						assertInput{flag: y}
						# if numHelper {
							# for i = 1; numHelper; 1 {
								# assertInput{flag: y; redirectID: helperIndex($i), ID}
							# }
						# }
					} else if map(_iksys_trialsButtonJam) = 6 {
						assertInput{flag: z}
						# if numHelper {
							# for i = 1; numHelper; 1 {
								# assertInput{flag: z; redirectID: helperIndex($i), ID}
							# }
						# }
					} else if map(_iksys_trialsButtonJam) = 7 {
						assertInput{flag: s}
						# if numHelper {
							# for i = 1; numHelper; 1 {
								# assertInput{flag: s; redirectID: helperIndex($i), ID}
							# }
						# }
					} else if map(_iksys_trialsButtonJam) = 8 {
						assertInput{flag: d}
						# if numHelper {
							# for i = 1; numHelper; 1 {
								# assertInput{flag: d; redirectID: helperIndex($i), ID}
							# }
						# }
					} else if map(_iksys_trialsButtonJam) = 9 {
						assertInput{flag: w}
						# if numHelper {
							# for i = 1; numHelper; 1 {
								# assertInput{flag: w; redirectID: helperIndex($i), ID}
							# }
						# }
					} else {
						mapSet{map: "_iksys_trialsButtonJamDelay"; value: 0;}
					}
				}
			}
		}
		if map(_iksys_trialsReposition) != 0 {
			call TrialsReposition(56);
			call TrialsReposition(57);
			mapSet{map: "_iksys_trialsReposition"; value: 0;}
		}
		# if map(_iksys_trialsCameraReset) != 0 {
			# call TrialsResetCamera();
			# mapSet{map: "_iksys_trialsCameraReset"; value: 0;}
		# }
	}
}