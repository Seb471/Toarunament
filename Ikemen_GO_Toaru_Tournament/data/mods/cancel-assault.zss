[Function cancelAssault() condition]
let condition = 0;
if(roundState=2 && (stateNo = [200,899] || hitDefAttr = SCA ,NA,NP,NT) && (prevStateNo = [0,199] || prevStateNo = stateNo)   && command = "cancelassault" && moveType = A && power>=500 && stateType!=A){
	let condition = 1;
	if (moveContact){
		let condition = 0;
	}
}

[StateDef 31143512;
type: S;
movetype: I;
physics: S;
anim: 100;
ctrl: 0;
sprpriority: 5;
poweradd:-500;]

if time = 0 {
	mapSet{
		map: "invulTime";
		value: 30-5*(log(2,map(lastCommand))+1);
	}
	afterImage{
		time: 30;
		palbright: 30,30,30;
		palcontrast: 170,120,220;
		palpostbright: 0,0,0;
	}
	playSnd{
		value: F 101, 1;
		volumescale: 50;
	}
	if map (lastCommand)>1{
		playSnd{value: F 101, 0}
	}
	if map(lastCommand)>2{
		ignoreHitPause {
			explod{
				anim: F 13200;
				id: 13200;
				pos: 30,const(size.head.pos.y);
				postype: P1;
				scale: 1.3,1.3;
				ownpal: 1;
				sprpriority: 5;
			}
		}
	}
}

if time > 1{
	ignoreHitPause persistent(3) if map(lastCommand) > 2 {
		explod{
		anim: F 13210;
		id: 13210;
		pos: 20,const(size.head.pos.y)-15+Random%90;
		postype: P1;
		scale: 1,1;
		vel: -1;
		ownpal: 1;
		sprpriority: 5;
		}
	}
}

if time = 10 {
	ctrlSet{value: 1}
}

# if time <= 16-(map(lastCommand)-1)*2{
	# palfx{
		# time: 1;
		# add: -64,-128,0;
	# }
	# notHitBy{value: SCA,NA, SA, NP, SP, NT, ST}
	# #if map(lastCommand) = 2 {notHitBy{value: SCA,NA, SA, NP, SP}}
	# #if map(lastCommand) = 1 {notHitBy{value: SCA,NA, SA, NP, SP, NT, ST}}
# }

velSet{x: const(velocity.run.fwd.x)/2+(0.25*map(lastCommand)*const(velocity.run.fwd.x))}



if time>=30 {
	changeState{value: 0; ctrl: 1}
}


[StateDef -4]
if !isHelper{
	if(stateNo = [0,199] ){
		mapSet{
			map: "lastCommand";
			value: 4*(command = "a" || command = "x")+2*(command = "b" || command = "y")+(command = "c" || command = "z");
		}
	}
	let condition = call cancelAssault();
	if ($condition){
		changeState{value: 31143512}
	}

	ignoreHitPause if map(invulTime)>0{
		palfx{
			time: 1;
			add: -64,-128,0;
		}
		notHitBy{value: SCA}
		#if map(lastCommand) = 2 {notHitBy{value: SCA,NA, SA, NP, SP}}
		#if map(lastCommand) = 1 {notHitBy{value: SCA,NA, SA, NP, SP, NT, ST}}
		if pauseTime = 0 && enemyNear,pauseTime = 0 {
			mapAdd{
				map: "invulTime";
				value: -1;
			}
		}
	}
}