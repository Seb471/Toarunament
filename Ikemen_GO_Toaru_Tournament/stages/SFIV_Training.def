;====================================================================
;ストリートファイターⅣから、トレーニングステージ(モドキ)　byJAM
;====================================================================
[Info]
name= "Experiment Room"                   ;ステージセレクト時の名前

;====================================================================
;■カメラ
[Camera]
startx         = 0                ;一番最初のｶﾒﾗ位置(X軸)
starty         = 0　　　　　　　　;一番最初のｶﾒﾗ位置(Y軸)
boundleft      = -185              ;左画面端の距離
boundright     = 185               ;右画面端の距離
boundhigh      = -45               ;上にｽｸﾛｰﾙする距離。0だとｽｸﾛｰﾙしない
boundlow       = .05　　　　   　　;下画面端の距離
verticalfollow = .4               ;ｼﾞｬﾝﾌﾟした時、ｽﾃｰｼﾞ全体が上下する強さ
tension        = 60            ;ﾄﾞｯﾄ数だけ画面端に行くと、ｽｸﾛｰﾙする

;====================================================================
;■キャラ
[PlayerInfo]
;--- Player 1 ---
p1startx   = -80                  ;1Pキャラの最初の立ち位置X軸
p1starty   = 0                    ;1Pキャラの最初の立ち位置Y軸
p1startz   = 0                    ;使用しない
p1facing   = 1                    ;1Pキャラの最初の向き。1だと、左向き 
;--- Player 2 ---
p2startx   = 80
p2starty   = 0
p2startz   = 0
p2facing   = -1
;--- Common ---　　　　         　;変える必要無し
leftbound  = -1000          
rightbound =  1000           
topbound   =  0           
botbound   =  0            

;====================================================================
;大きさ
[Scaling]                   
topz     = 0
botz     = 50
topscale = 1
botscale = 1.2

;====================================================================
;座標
[Bound]                   
screenleft  = 15                  ;左画面端の壁の存在距離
screenright = 15                  ;右画面端の壁の存在距離

;====================================================================
;情報
[StageInfo]
zoffset  = 220            
autoturn = 1                       ;ｷｬﾗが自動的に振り向くか(1で振り向く。基本的に1
resetBG  = 0                       ;ﾗｳﾝﾄﾞ終了後ｱﾆﾒをﾘｾｯﾄするか(1でon)

;====================================================================
;影
[Shadow]
color      = 80,80,80        ;影の色（数値が多いほど濃くなる）
yscale     = 0.3            ;影の方向（数値を０未満に指定すると影が奥に伸びる）
reflect    = 0             ;キャラの姿を床に反射させるかどうか（1=反射,0=反射させない）
intensity  = 64          ;影の濃さ（0薄い、255濃い）
fade.range = -335,-5    ;影のフェードアウト設定（影の方向を奥側にした場合に特に有効）
                        ;※初めの値は影が完全に消える高さ、後ろの値は影が消え始める高さ              
[Reflection]
intensity  = 0           ;反射の強さ(0から256)　デフォルトは0

;====================================================================
;音声
[Music]
bgmusic= sound/SEARCHER.mp3       ;ｽﾃｰｼﾞ専用曲の指定(midやmp3やmodが使用可能)
bgvolume = 255                     ;BGMの音量(0～255)

;====================================================================
;画像ファイルの指定
[BGdef]
spr=stages/cvs2&cfj_Training.sff         ;ｽﾃｰｼﾞの画像ﾌｧｲﾙの指定
debugbg = 0  　　　　　　　　      ;1にすると、画像が無い部分に、残像がつかない。

;====================================================================
;ステージ画像位置等
;====================================================================
;足場メイン
[BG 00]
type        = Parallax    ;画像表示タイプ。Normal=静止画、Anim=アニメ画、Parallax=立体静止画（一点透視図法）
spriteNo    = 2,0       ;画像ファイル（*.sff）の画像を表示。Animの時は必要無し
layerNo     = 0         ;レイヤー属性。0=奥、1=手前に表示
start       = 0,0       ;軸位置。このdefファイルで設定した軸位置から数える
delta       = 0.73,1.0 ;キャラが動いた時のスクロールスピード。小数点以下可能
trans       = None     ;透過処理。Add=加算処理（輝く半透明）,Add1=半透明,Sub=減算処理（影の半透明）,None=透過しない
mask        = 1         ;画像の背景色を透過させるかどうか。1=Yes,0=No
tile        = 0,0       ;タイル化して同じ画像を複数表示させるかどうか（それぞれX,Y）
tilespacing = 0,0       ;タイル化した画像同士の間隔。
ActionNo    = 0         ;使用するアニメのナンバー。
velocity    = 0,0       ;画像の移動速度
xscale      = 1,1.7

;====================================================================
;足場サブパーツ
[BG 01]
type        = Parallax    ;画像表示タイプ。Normal=静止画、Anim=アニメ画、Parallax=立体静止画（一点透視図法）
spriteNo    = 2,1       ;画像ファイル（*.sff）の画像を表示。Animの時は必要無し
layerNo     = 0         ;レイヤー属性。0=奥、1=手前に表示
start       = 0,0       ;軸位置。このdefファイルで設定した軸位置から数える
delta       = 0.73,1.0 ;キャラが動いた時のスクロールスピード。小数点以下可能
trans       = None     ;透過処理。Add=加算処理（輝く半透明）,Add1=半透明,Sub=減算処理（影の半透明）,None=透過しない
mask        = 1         ;画像の背景色を透過させるかどうか。1=Yes,0=No
tile        = 0,0       ;タイル化して同じ画像を複数表示させるかどうか（それぞれX,Y）
tilespacing = 0,0       ;タイル化した画像同士の間隔。
ActionNo    = 0         ;使用するアニメのナンバー。
velocity    = 0,0       ;画像の移動速度
xscale      = 1,1.7


;====================================================================
;足場影パーツ
[BG 02]
type        = Normal    ;画像表示タイプ。Normal=静止画、Anim=アニメ画、Parallax=立体静止画（一点透視図法）
spriteNo    = 2,2       ;画像ファイル（*.sff）の画像を表示。Animの時は必要無し
layerNo     = 0         ;レイヤー属性。0=奥、1=手前に表示
start       = 0,0       ;軸位置。このdefファイルで設定した軸位置から数える
delta       = 0.75,1.0 ;キャラが動いた時のスクロールスピード。小数点以下可能
trans       = addalpha     ;透過処理。Add=加算処理（輝く半透明）,Add1=半透明,Sub=減算処理（影の半透明）,None=透過しない
mask        = 1         ;画像の背景色を透過させるかどうか。1=Yes,0=No
tile        = 0,0       ;タイル化して同じ画像を複数表示させるかどうか（それぞれX,Y）
tilespacing = 0,0       ;タイル化した画像同士の間隔。
ActionNo    = 0         ;使用するアニメのナンバー。
velocity    = 0,0       ;画像の移動速度
alpha       = 60,250    ;"trans"の項目が"addalpha"の場合の設定。範囲はそれぞれ0～256"AS000D???"の使い方と酷似します。

;====================================================================
;奥背景メイン
[BG 03]
type        = Normal    ;画像表示タイプ。Normal=静止画、Anim=アニメ画、Parallax=立体静止画（一点透視図法）
spriteNo    = 3,0       ;画像ファイル（*.sff）の画像を表示。Animの時は必要無し
layerNo     = 0         ;レイヤー属性。0=奥、1=手前に表示
start       = 0,0       ;軸位置。このdefファイルで設定した軸位置から数える
delta       = 0.75,1.0 ;キャラが動いた時のスクロールスピード。小数点以下可能
trans       = None     ;透過処理。Add=加算処理（輝く半透明）,Add1=半透明,Sub=減算処理（影の半透明）,None=透過しない
mask        = 1         ;画像の背景色を透過させるかどうか。1=Yes,0=No
tile        = 0,0       ;タイル化して同じ画像を複数表示させるかどうか（それぞれX,Y）
tilespacing = 0,0       ;タイル化した画像同士の間隔。
ActionNo    = 0         ;使用するアニメのナンバー。
velocity    = 0,0       ;画像の移動速度

