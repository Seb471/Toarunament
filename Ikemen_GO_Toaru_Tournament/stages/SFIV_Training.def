spriteNo    = 3,2       ;画像ファイル（*.sff）の画像を表示。Animの時は必要無し
layerNo     = 0         ;レイヤー属性。0=奥、1=手前に表示
start       = 0,0       ;軸位置。このdefファイルで設定した軸位置から数える
delta       = 0.75,1.0 ;キャラが動いた時のスクロールスピード。小数点以下可能
trans       = addalpha     ;透過処理。Add=加算処理（輝く半透明）,Add1=半透明,Sub=減算処理（影の半透明）,None=透過しない
