[State -2, 距離確認デバック]
type = AppendToClipboard
trigger1 = 1
text =  "P2X:%f,P2Y:%f,Vx%f,Vy%f,Py%f \n"
params = p2bodydist x, p2bodydist y,vel x,vel y,Pos y
IgnoreHitPause = 1