	trigger1 = enemy,movetype != H
	trigger2 = enemy,stateno = [120,155]
	fvar(0) = 1
	ignorehitpause = 1

[State -2];cornerpush reset
	type = Varset
	trigger1 = enemy,movetype != H
	trigger2 = enemy,stateno = [120,155]
	fvar(11)=0
	ignorehitpause = 1
	
