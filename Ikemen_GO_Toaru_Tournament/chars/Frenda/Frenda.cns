;---------------------------------------------------------------------------
; States that are always executed (use statedef -2)
;---------------------------------------------------------------------------
[Statedef -2]

;---------------------------------------------------------------------------
;Counter
;---------------------------------------------------------------------------
[State -2]
 	type = Varset
 	trigger1 = enemynear,movetype = A
	var(2) = 1
	ignorehitpause = 1

[State -2]
 	type = Varset
 	;triggerall = stateno !=[6300,6350] -> burst
 	;triggerall = stateno !=[6400,6425] -> parry mechanic
 	triggerall = stateno !=[800,849] ; -> grab states
 	triggerall = movetype != H
 	triggerall = enemynear,movetype = H 
 	triggerall = var(2) = 1
 	trigger1 = movehit
	trigger2 = helper(2420),movehit
	var(2) = 2
	ignorehitpause = 1

[State -2, カウンターアタックボイス]
	type = PlaySnd
	trigger1 = var(2)=2
	value = 1, 33
	ignorehitpause = 1

[State -2]
	type = Explod
	trigger1 = var(2) = 2
	trigger2 = numexplod(14000) = 0
	trigger2 = var(2) = 3
	anim = ifelse(var(2)=2,14000,14002)
	ID = 14000
	pos = ifelse(teamside=1,60,260),  60
	postype = left
	bindtime = -1
	removetime = -1
	supermovetime = 9999
	pausemovetime = 9999
	sprpriority = 9999
	scale = .5,.5
	ontop = 1
	ownpal = 1
	ignorehitpause = 1

[State -2]
 	type = Varset
 	trigger1 = var(2) = 2
	var(2) = 3
	ignorehitpause = 1

[State -2]
	type = RemoveExplod
	trigger1 = enemynear,movetype = I
	trigger2 = target,stateno =[5110,5120]
	trigger3 = RoundState = 3
	ID = 14000
	ignorehitpause = 1
	
[State -2]
	type = Explod
	triggerall =var(2) != 0
	triggerall =var(2) != 1
	trigger1 = enemynear,movetype = I
	trigger2 = target,stateno =[5110,5120]
	trigger3 = RoundState = 3
	anim = 14001
	pos = ifelse(teamside=1,60,260),  60
	postype = left
	bindtime = -1
	supermovetime = 9999
	pausemovetime = 9999
	sprpriority = 9999
	scale = .5,.5
	ontop = 1
	ownpal = 1
	ignorehitpause = 1

[State -2]
 	type = Varset
	trigger1 = enemynear,movetype = I
	trigger2 = target,stateno =[5110,5120]
	trigger3 = RoundState = 3
	var(2) = 0
	ignorehitpause = 1

[State -2, DefenceMulSet]
Type = DefenceMulSet
Trigger1 = Life <= 300
Value = 0.7
IgnoreHitPause = 1

[State -2, DefenceMulSet]
Type = DefenceMulSet
Trigger1 = Life <= 150
Value = 0.5
IgnoreHitPause = 1

[State -2, PowerAdd]
type = PowerAdd
trigger1 = 1
value = 0

[State 0, Width]
type = Width
trigger1 = stateno!=[2000,3999]
edge = 15,0
;value = 0,0
ignorehitpause = 1
;persistent = 


;Gives 1000 at the start of the battle
[State -2,初期ゲージ設定]
	Type= PowerSet
	trigger1 = roundsexisted = 0 && roundstate = 0 && roundno = 1;
	value = 1000 ; 0〜6000で設定可能 1000単位で1本 デフォルトは1000

;Bomb Number Reset
[State -2]
	type = Varset
	trigger1 = roundstate = 0
	var(4)=0
	ignorehitpause = 1


;Special Reset Set
[State -2]
	type = Varset
	trigger1 = roundstate = 0
	var(13)=0
	ignorehitpause = 1


;Backdash count Reset
[State -2]
	type = Varset
	trigger1 = stateno!=[105,106] && var(6)!=0
	var(6)=0
	ignorehitpause = 1


;Set Bomb mode to remote controlled
[State -2,初期ゲージ設定]
	Type= Varset
	trigger1 = roundsexisted = 0 && roundstate = 0
	var(3)=1 ; 0〜6000で設定可能 1000単位で1本 デフォルトは1000


;Set Timer to 6 seconds
[State -2,初期ゲージ設定]
	Type= Varset
	trigger1 = roundsexisted = 0 && roundstate = 0
	var(5)=6 ; 0〜6000で設定可能 1000単位で1本 デフォルトは1000

;;Coat Protection from everything
[State 0, NotHitBy]
type = NotHitBy
triggerall= abs(pos Y - helper(765),pos Y) <= 80
trigger1 = numhelper(765)>0 && helper(765),stateno =765
trigger1= abs(pos X - helper(765),pos X) <= abs(p2dist X)
trigger1 =  pos X - helper(765),pos X < 0 && facing = 1
trigger2 = numhelper(765)>0 && helper(765),stateno =765
trigger2= abs(pos X - helper(765),pos X) <= abs(p2dist X)
trigger2 =  pos X - helper(765),pos X > 0 && facing = -1
trigger3 = numhelper(765)>0 && helper(765),stateno =766
trigger3 =  pos X - helper(765),pos X > 0 && facing = -1
trigger4 = numhelper(765)>0 && helper(765),stateno =766
trigger4 =  pos X - helper(765),pos X < 0 && facing = 1

value = SA,NA,SA,HA,NP,SP,HP
;value2 = S,NA
time = 1
ignorehitpause = 1
;persistent = 

[State 0, Helper]
type = Helper
triggerall = power>299
triggerall=numhelper(765)=0
triggerall=command="QCF_z"
triggerall= P2dist X >65
trigger1=ctrl
trigger2=stateno=[100,101]
helpertype = normal ;player
name = "Coat"
ID = 765
stateno = 765
pos = 20,floor(-30*const(Size.yScale))
postype = p1    ;p2,front,back,left,right
facing = 1
keyctrl = 0
ownpal = 1
supermovetime = 0
pausemovetime = 0
ignorehitpause = 1
persistent=0

;Kick bounce reset
[State -2]
	type = Varset
	trigger1 = enemy,movetype != H
	trigger2 = enemy,stateno = [120,155]
	var(7)=0
	ignorehitpause = 1

;DamageDampening Reset
[State -2]
	type = Varset
	trigger1 = enemy,movetype != H
	trigger2 = enemy,stateno = [120,155]
	fv = 0
	value = 1
	ignorehitpause = 1


