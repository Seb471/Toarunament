;---------------------------------------------------------------------------
; States that are executed when in self's state file (use statedef -3)
;---------------------------------------------------------------------------

[Statedef -3]


;This controller plays a sound everytime KFM lands from a jump, or
;from his back-dash.
[State -3, Landing Sound]
type = PlaySnd
triggerall = Time = 1
trigger1 = stateno = 52 ;Jump land
trigger2 = stateno = 106 ;Run-back land
value = 40, 0

;Gethit sounds
[State -3, Get Hit Sounds]
type = PlaySnd
triggerall = alive && time = 1
trigger1 = (stateno = 5000 || stateno = 5010 || stateno = 5020 || stateno = 5070 || stateno = 5080)
trigger1 = enemynear,hitdefattr = SCA,NA,SA,HA
value = S5000,0+(random%9)
volume = 255
channel = 0

;KO Sound
[State -3, 変数 KOボイス重複スイッチ初期化]
type = VarSet
trigger1 = var(43)
trigger1 = Alive
var(43) = 0
ignorehitpause = 1

[State -3, KOボイス]
type = playsnd
trigger1 = !Alive
trigger1 = !Var(43)
triggerall = alive=0
triggerall= !(enemy,name = "Mugino Shizuri") || !(enemy,stateno =[2000,3500]) || !(roundsexisted>=1) || (!lose) 
;trigger1 = time = 0
value = S5200,(roundsexisted>1)*1+ 0+(random%4)
channel = 2
lowpriority = 1
ignorehitpause = 1

[State -3, KOボイス]
type = playsnd
triggerall = !Alive
triggerall = !Var(43)
triggerall = alive=0
triggerall= enemy,name = "Mugino Shizuri"
triggerall= enemy,stateno =[2000,3500] 
Trigger1=roundsexisted >=1
TRIGGER1=lose
Trigger2=roundsexisted >=2
;trigger1 = time = 0
value = S5201,0
channel = 2
lowpriority = 1
ignorehitpause = 1

[State -3, 変数 KOボイス重複防止]
type = VarSet
trigger1 = !var(43)
trigger1 = !Alive
var(43) = 1
ignorehitpause = 1


[State 0, StopSnd]
type = StopSnd
trigger1 = roundstate = 2 && time = 0 && stateno = 0
channel = 2
;ignorehitpause = 
;persistent =




;Var(1) is for combos
;var(2) for counter attack
;var(3) =0 is time bombs =1 is remote controlled
;var(4) is bomb count
;var(5) is for bomb timer
;Var(6) is for backdash count
;Var(7) is bounce count
;Var(12) is the "was getting hit" boolean
;Var(13) is the special bomber recovery trigger
;Var(14) is for the burst
;Var(15) is the dodge setup count
;var(33) is intro random var
;fvar(0) damage dampen
;fvar(6) 
;fvar(7) 
;fvar(10) guaranteed damage
;fvar(11) cornerpush
;fvar(12) 
 
