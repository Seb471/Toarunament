;==============================================================================
; Win版専用パート
;==============================================================================
;------------------------------------------------------------------------------
; ここはWin版から（正確にはLinux版から）追加された要素の二つ。
; コマンド関連の初期設定を任意に指定出来るようになった(`・ω・´)
;
;『ボタンリマップ』はボタン配置変更用の項目。
; 定義パートでいちいち変更しなくても良いようになっちゃった。
; 面倒臭い人用かな！（ﾏﾃｺﾗ
;
;『デフォルト設定』では各[Command]で省略した場合の
; 入力受付時間と入力記憶時間を予め決めておく項目。
;
;
; この２項目は省略可能。
;------------------------------------------------------------------------------
;-| ボタンリマップ（ボタンコンフィグ）|----------------------------------------
[Remap]
x = x      ;Ｘボタンの入力判定を実際に押すボタンに割り当てる。
y = y      ;Ｙボタン　　　　　　　　　〃
z = z      ;Ｚボタン　　　　　　　　　〃
a = a      ;Ａボタン　　　　　　　　　〃
b = b      ;Ｂボタン　　　　　　　　　〃
c = c      ;Ｃボタン　　　　　　　　　〃
s = s      ;スタートボタン　　　　　　〃

;-| デフォルト設定 |-----------------------------------------------------------
[Defaults]
command.time = 15

command.buffer.time = 1



;-| 超必殺技 |-----------------------------------------------------------------
[Command]
name = "血流操作"
command = ~B, DB, D, DF, F, a
time = 20
buffer.Time=10

[Command]
name = "空気圧縮"
command = ~B, DB, D, DF, F, b
time = 20
buffer.Time=10

[Command]
name = "超空気圧縮"
command = ~B, DB, D, DF, F, c
time = 20
buffer.Time=10

[Command]
name = "黒翼"
command = ~B, DB, D, DF, F, x
time = 20
buffer.Time=10

[Command]
name = "竜巻EX"
command =  ~F, D, DF, c
time = 20
buffer.Time=10

[Command]
name = "風巻上げEX"
command =  ~D, DF, F , c
time = 20
buffer.Time=10

[Command]
name = "血液逆流EX"
command=~D,DB,B,c
time = 20
buffer.Time=10

[Command]
name = "ベクトルキックEX"
command=~D,DB,B,c
time = 20
buffer.Time=10

[Command]
name = "地面砕きEX"
command =  ~D, D, b
time = 20
buffer.Time=10

[Command]
name = "粉塵爆発"
command =  ~D, D, c
time = 20
buffer.Time=10

;-| 必殺技 |-------------------------------------------------------------------
[Command]
name = "竜巻A"
command = F, D, DF, a
time = 20
buffer.Time=10

[Command]
name = "竜巻B"
command = F, D, DF, b
time = 20
buffer.Time=10

;---------------------------
[Command]
name = "風巻上げA"
command = D, DF, F , a
time = 20
buffer.Time=10

[Command]
name = "風巻上げB"
command = D, DF, F , b
time = 20
buffer.Time=10

;---------------------------
[Command]
name = "血液逆流A"
command=~D,DB,B,a
;command = B, DB, D, DF, F, a
time = 20
buffer.Time=10

[Command]
name = "血液逆流B"
command=~D,DB,B,b
;command = B, DB, D, DF, F, b
time = 20
buffer.Time=10

;---------------------------
[Command]
name="ベクトルキックA"
command=~D,DB,B,a
time = 20
buffer.Time=10

[Command]
name="ベクトルキックB"
command=~D,DB,B,b
time = 20
buffer.Time=10

;---------------------------
[Command]
name = "地面砕き"
command = D, D, a
time = 20
buffer.Time=10

;-| 特殊 |-------------------------------------------------------------------
[Command]
name = "飛び道具反射"
command = D, D,y
time = 20
buffer.Time=10

[Command]
name = "打撃反射"
command = y,y
time = 20
buffer.Time=10

[Command]
name = "ブーストダッシュ"
command = D, DF, F , y
time = 20
buffer.Time=10

[Command]
name = "ブーストバック"
command=~D,DB,B,y
time = 20
buffer.Time=10

[Command]
name = "緊急回避"
command = a+b
time = 10
;------------------------------------------------------------------------------
;-| キー２回連続入力 |---------------------------------------------------------
[Command]
name = "FF"       ;必須コマンド名
command = F, F
time = 10

[Command]
name = "BB"       ;必須コマンド名
command = B, B
time = 10

;------------------------------------------------------------------------------
;-| 同時押し |-----------------------------------------------------------------

[Command]
name = "recovery" ;必須コマンド名
command = x+y
time = 1

;------------------------------------------------------------------------------
;-| 方向キー＋ボタン |---------------------------------------------------------

[Command]
name = "down_a"
command = /$D,a
time = 1

[Command]
name = "down_b"
command = /$D,b
time = 1

;------------------------------------------------------------------------------
;-| ボタン単発 |---------------------------------------------------------------

[Command]
name = "a"
command = a
time = 1

[Command]
name = "b"
command = b
time = 1

[Command]
name = "c"
command = c
time = 1

[Command]
name = "x"
command = x
time = 1

[Command]
name = "y"
command = y
time = 1

[Command]
name = "z"
command = z
time = 1

[Command]
name = "start"
command = s
time = 1

;---------------------------
[Command]
name = "hold_a"
command = /a
time = 1

[Command]
name = "hold_b"
command = /b
time = 1

[Command]
name = "hold_c"
command = /c
time = 1

[Command]
name = "hold_x"
command = /x
time = 1

[Command]
name = "hold_y"
command = /y
time = 1

;------------------------------------------------------------------------------
;-| 方向キー |-----------------------------------------------------------------

[Command]
name = "holdfwd"   ;必須コマンド名
command = /$F
time = 1

[Command]
name = "holdback"  ;必須コマンド名
command = /$B
time = 1

[Command]
name = "holdup"    ;必須コマンド名
command = /$U
time = 1

[Command]
name = "holddown"  ;必須コマンド名
command = /$D
time = 1

[statedef 21]
type    = S
physics = S
sprpriority = 0

[State 21, 移動速度] ;前進する速度
type = VelSet
trigger1 = var(59)||fvar(39)
x = const(velocity.walk.fwd.x) ;定数で設定した速度

[State 21, アニメ変更] ;前進するアニメに変更
type = ChangeAnim
triggerall = vel x > 0
trigger1 = Anim != 20 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 20


[Statedef 22]
type    = S
physics = S
sprpriority = 0

[State 22, 移動速度] ;後退する速度
type = VelSet
trigger1 = var(59)||fvar(39)
x = const(velocity.walk.back.x) ;定数で設定した速度

[State 22, アニメ変更] ;後退するアニメに変更
type = ChangeAnim
triggerall = vel x < 0
trigger1 = Anim != 21 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 21

;==============================================================================
; 準常時監視ステート
;==============================================================================
[Statedef -1]
;==============================================================================
; 超必殺技
;==============================================================================
;-----------------------------------5ゲージ-------------------------------------


;-----------------------------------4ゲージ-------------------------------------
[State -1, 黒翼]
	type = ChangeState
	value = 2800
	triggerall=!var(59)
	triggerall = command = "黒翼"
	triggerAll = statetype != A
	TriggerAll = Power>3999
	triggerAll = var(3)<=500 || var(18)
	TriggerAll=Life < 0.3*LifeMax || PalNo >= 9
	trigger1 = ctrl
	trigger2 = stateno = 1000 && var(1);風巻上げAキャンセル
	trigger3 = stateno = 1101 && var(1);竜巻A派生キャンセル
	trigger4 = stateno = 1205 && var(1);血液逆流Aキャンセル
	trigger5 = stateno = 2000 && var(1);風巻上げEXキャンセル

[State -1, 空気.zip（超電磁版）]
	type = ChangeState
	value = 2700
	triggerall=!var(59)
	triggerall = command = "超空気圧縮"
	triggerAll = statetype != A
	TriggerAll=Power>3999
	triggerAll = var(3)<=700 || var(18)
	trigger1 = ctrl
	trigger2 = stateno = 2100 && var(1);竜巻EXキャンセル
	trigger3 = stateno = 2500 && var(1);竜巻EXキャンセル
	Trigger4 = StateNo = 6100 && var(1)
;-----------------------------------3ゲージ-------------------------------------
[State -1, 空気.zip]
	type = ChangeState
	value = 2600
	triggerall=!var(59)
	triggerall = command = "空気圧縮"
	triggerAll = statetype != A
	TriggerAll=Power>2999
	trigger1 = ctrl
	trigger2 = stateno = 1205 && var(1);血液逆流Aキャンセル
	trigger3 = stateno = 1390 && var(1);ベクトルキック着地キャンセル
	trigger4 = stateno = 2000 && var(1);風巻上げEXキャンセル
	trigger5 = stateno = 2100 && var(1);竜巻EXキャンセル	
	trigger6 = stateno = 2410 && var(1);血液操作キャンセル
;-----------------------------------2ゲージ-------------------------------------
[State -1, 血流操作]
	type = ChangeState
	value = 2400
	triggerall=!var(59)
	triggerall = command = "血流操作"
	triggerAll = statetype != A
	TriggerAll=Power>1999
	trigger1 = ctrl
	trigger2 = (stateno = [200,599]) && var(1);地上通常攻撃キャンセル
	trigger3 = stateno = 1205 && var(1);血液逆流Aキャンセル
	trigger4 = stateno = 1215 && var(1);血液逆流Bキャンセル

[State -1, 粉塵爆発]
	type = ChangeState
	value = 2500
	triggerall=!var(59)
	triggerall = command = "粉塵爆発"
	triggerAll = statetype != A
	TriggerAll=Power>1999
	trigger1 = ctrl
	trigger2 = (stateno = [200,599]) && var(1);地上通常攻撃キャンセル
	trigger3 = stateno = 1000 && var(1);風巻上げAキャンセル
	trigger4 = stateno = 2000 && var(1);風巻上げEXキャンセル
	trigger5 = stateno = 2100 && var(1);竜巻EXキャンセル

;-----------------------------------1ゲージ-------------------------------------
[State -1, 竜巻EX]
	type = ChangeState
	value = 2100
	triggerall=!var(59)
	triggerall = command = "竜巻EX"
	triggerAll = statetype != A
	TriggerAll=Power>999
	trigger1 = ctrl
	trigger2 = stateno =  220 && var(1);5b（タメ含む）キャンセル
	trigger3 = stateno = 2000 && var(1);風巻上げEXキャンセル

