;==============================================================================
; 移動関連
;==============================================================================
;------------------------------------------------------------------------------
[State -1,JumpC];ジャンプキャンセル
	Type=ChangeState
	value=40
	triggerall=!var(59)
	TriggerAll = StateType != A
	TriggerAll = command = "holdup"
	Trigger1 = StateNo =  100 && animelemtime(4)>=0
	Trigger2 = StateNo = 1500 && var(1)
	Trigger3 = StateNo = 2300 && var(1)
	trigger4 = stateno = 53
	Trigger4 = (!var(1) && time >= 3) ||(var(1) && time >= 9)
	Trigger5 = StateNo = 1101 && var(1)

[State -1, 走る]
	type = ChangeState
	value = 100
	triggerall=!var(59)
	TriggerAll = command = "FF"
	TriggerAll = statetype != A
	trigger1 = ctrl

[State -1, バックステップ]
	type = ChangeState
	value = 105
	triggerall=!var(59)
	TriggerAll = command = "BB"
	TriggerAll = statetype != A
	trigger1 = ctrl

[State -1,空中ダッシュ]
	Type=ChangeState
	value=110
	triggerall=!var(59)
	TriggerAll = Alive
	TriggerAll = command="FF"
	TriggerAll = StateType=A
