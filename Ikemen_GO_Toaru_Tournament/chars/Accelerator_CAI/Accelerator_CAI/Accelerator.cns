[Size]
	xscale           = 1       ;僉儍儔偺墶偺戝偒偝乮愨懳抣丒float乯
	yscale           = 1       ;僉儍儔偺廲偺戝偒偝乮愨懳抣丒float乯
	ground.back      = 15      ;抧忋偵偄傞帪偺乽屻曽偺暔棟揑側暆乿
	ground.front     = 16      ;抧忋偵偄傞帪偺乽慜曽偺暔棟揑側暆乿
	air.back         = 12      ;嬻拞偵偄傞帪偺乽屻曽偺暔棟揑側暆乿
	air.front        = 12      ;嬻拞偵偄傞帪偺乽慜曽偺暔棟揑側暆乿
	height           = 60      ;僉儍儔偺暔棟揑側崅偝乮崅偄傎偳憡庤偼旘傃墇偟偵偔偔側傞乯
	attack.dist      = 160     ;憡庤偑僈乕僪懺惃偵擖傞嵟掅偺嫍棧
	proj.attack.dist = 90      ;帺暘偺乽Projectile乿偵懳偟偰憡庤偑僈乕僪懺惃偵擖傞嵟掅偺嫍棧
	proj.doscale     = 0       ;xscale偲yscale傪乽Projectile乿偵傕塭嬁偝偣傞偐斲偐乮0=偝偣側偄丒1=偝偣傞乯
	head.pos         = -5,-90  ;僉儍儔偺昗弨偺摢偺嵗昗乮Bind宯偱揔梡偝傟傞乯
	mid.pos          = -5,-60  ;僉儍儔偺昗弨偺懱拞怱偺嵗昗乮Bind宯偱揔梡偝傟傞乯
	shadowoffset     = 0       ;塭偺倄幉曽岦偺埵抲嵗昗
	draw.offset      = 0,0     ;僉儍儔偺昞帵嵗昗乮倃幉,倄幉乯

