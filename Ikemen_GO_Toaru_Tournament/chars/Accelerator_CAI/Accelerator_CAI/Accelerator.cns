[Data]
	life              = 820   ;儔僀僼乮懱椡僎乕僕乯嵟戝抣
	power             = 6000   ;僷儚乕僎乕僕嵟戝抣乮僆僾僔儑儞丒僨僼僅儖僩偼3000=Lv.3乯
	attack            = 100    ;峌寕椡乮僨僼僅儖僩偼侾侽侽亾乯
	defence           = 100    ;杊屼椡乮僨僼僅儖僩偼侾侽侽亾乯
	fall.defence_up   = 50     ;墶偵搢傟偰偄傞帪偵堦帪揑偵壛偊傞杊屼椡乮亾乯
	liedown.time      = 60     ;墶偵搢傟偰偄傞帪娫乮僼儗乕儉乯
	airjuggle         = 15     ;僕儍僌儖億僀儞僩尷奅抣乮乽彫僱僞.txt乿嶲徠乯
	sparkno           = 2      ;僨僼僅儖僩偺僸僢僩僗僷乕僋乮fightfx偐傜乯
	guard.sparkno     = 40     ;僨僼僅儖僩偺僈乕僪僗僷乕僋乮fightfx偐傜乯
	KO.echo           = 0      ;俲俷帪偺壒惡乮11,0乯偵僄僐乕傪妡偗傞偐斲偐乮0=妡偗側偄,1=妡偗傞乯
	volume            = 255    ;僉儍儔偺昗弨偺壒検乮嵟彫-255丒嵟戝255乯
	IntPersistIndex   = 0     ;師偺儔僂儞僪傊帩偪墇偣傞乽Var乿偺傾僪儗僗偺斖埻傪寛傔傞乮仸侾乯
	FloatPersistIndex = 39     ;師偺儔僂儞僪傊帩偪墇偣傞乽FVar乿偺傾僪儗僗偺斖埻傪寛傔傞乮仸侾乯

