	run.back     = -4.5,-3.8   ;屻曽偵憱傞懍搙乮倃幉,倄幉丒[Statedef 105]偵揔梡偝傟傞乯
	
	jump.neu     = 0,-11.5     ;悅捈僕儍儞僾偺懍搙乮倃幉,倄幉丒[Statedef 40]偵揔梡偝傟傞乯
	jump.back    = -4          ;屻曽僕儍儞僾偺懍搙乮倃幉丒[Statedef 40]偵揔梡偝傟傞乯
	jump.fwd     = 3.5         ;慜曽僕儍儞僾偺懍搙乮倃幉丒[Statedef 40]偵揔梡偝傟傞乯
	
	runjump.back = -2.55,-8.1  ;屻曽偵憱偭偰偐傜偺僕儍儞僾懍搙乮倃幉,倄幉丒[Statedef 40]偵揔梡偝傟傞乯
	runjump.fwd  = 5,-6.1      ;慜曽偵憱偭偰偐傜偺僕儍儞僾懍搙乮倃幉,倄幉丒[Statedef 40]偵揔梡偝傟傞乯

	airjump.neu  = 0,-8.1      ;嬻拞悅捈僕儍儞僾懍搙乮倃幉,倄幉丒[Statedef 45]偵揔梡偝傟傞乯
	airjump.back = -2.55       ;嬻拞屻曽僕儍儞僾懍搙乮倃幉丒[Statedef 45]偵揔梡偝傟傞乯
	airjump.fwd  = 2.5         ;嬻拞慜曽僕儍儞僾懍搙乮倃幉丒[Statedef 45]偵揔梡偝傟傞乯

