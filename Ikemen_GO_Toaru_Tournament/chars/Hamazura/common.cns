; Jump Land
[Statedef 52]
physics = S
sprpriority = 0
velset = Var(12)*0.001*Facing,0
ctrl = 0

[State ]
Type = PlaySnd
Trigger1 = Time = 0 && PrevStateNo != 0
Value = s40, 1

[State ]
Type = CtrlSet
Trigger1 = (PrevStateNo != [110,119]) && (PrevStateNo != [600,699]) && PrevStateNo != 760 && (PrevStateNo != [810,839]) && PrevStateNo != 860 && (PrevStateNo != [920,925]) && PrevStateNo != 970 && PrevStateNo != 5201 && (PrevStateNo != [1200,1299]) && (PrevStateNo != [2200,2299]) && PrevStateNo != 1325 && (PrevStateNo != [1600,1699]) && PrevStateNo != 2600 && PrevStateNo != 1700
Trigger1 = Time = 0
Trigger2 = (PrevStateNo = [110,119]) && Time = 8
Trigger3 = (PrevStateNo = [600,639]) && Time = Cond(Var(57)%10=3,0,2)
Trigger4 = (PrevStateNo = 760 || (PrevStateNo = [820,829])) && Time = 12 || PrevStateNo = 810 && Time = 14 || (PrevStateNo = [830,839]) && Time = 8 || PrevStateNo = 5201 && Time = 1
Trigger5 = (PrevStateNo = 860 || (PrevStateNo = [920,923]) || PrevStateNo = 970) && Time = 14 || (PrevStateNo = [920,923]) && Var(2)/100%10 != 0 || PrevStateNo = 925 && Time = 2
Trigger6 = (PrevStateNo = 1200 || PrevStateNo = 1210 || (PrevStateNo = [1250,1260]) || PrevStateNo = 2200 || PrevStateNo = 2250) && Time = 11 || ((PrevStateNo = [2205,2240]) || (PrevStateNo = [1600,1699]) || PrevStateNo = 1700) && Time = 14 || PrevStateNo = 1325 && Time = 8 || PrevStateNo = 2600 && Time = 13
Value = 1

[State ]
Type = VarSet
Trigger1 = Var(9) = 0 && PrevStateNo != 1650 && Time = 0 || Var(9) > 0
V = 2
Value = Cond(Var(9)=0&&Time=0,0,Cond(Var(2)/1000>0,Var(2)/1000%10*1000,0)+402)

[State ]
Type = Turn
Trigger1 = PrevStateNo = 810
Trigger1 = Time = 0

[State ]
type = ChangeAnim
trigger1 = Time = 0 && Anim != [47,59]
value = 47+(Anim=61||Anim=110||Anim=810||Anim=830||Anim=1325)+(Anim=62||(Anim=[115,119])||(Anim=[5200,5210]))*2+(P2Dist X<0&&((EnemyNear(Var(3)),BackEdgeDist!=[-1,1])||Facing+EnemyNear(Var(3)),Facing!=0))*10

[State ]
Type = Turn
Trigger1 = Time = 0 && Anim = [57,59]

[State ]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State ]
Type = VarSet
Trigger1 = Time = 0
sysvar(3) = 0

[State ]
type = PosSet
trigger1 = Time = 0
y = 0

[State ]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1


